# Copy to .env.local for local Docker smoke testing.
# In production, set these as `fly secrets set ...` — do NOT commit real values.

# --- Database (Supabase) ---
# Use the "Connection pooling" (Transaction mode) URI from Supabase > Project Settings > Database.
# Must include ?sslmode=require
DATABASE_URL=postgresql://postgres.xxxxxxxx:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require

# --- Auth ---
SECRET_KEY=replace-with-a-long-random-string

# --- Media storage (Cloudflare R2) ---
USE_CLOUD_STORAGE=true
S3_ENDPOINT_URL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=gladney-family-media
# Public URL base for served objects (R2 public bucket or custom domain, no trailing slash)
S3_PUBLIC_URL=https://media.mrtag.com
